            { category: "Genetics", q: "What enzyme 'unzips' the DNA double helix during replication?", a: "Helicase." },
            { category: "Genetics", q: "What enzyme seals the nicks between Okazaki fragments on the lagging strand?", a: "DNA Ligase." },
            { category: "Genetics", q: "What is transcription?", a: "The synthesis of an RNA molecule from a DNA template." },
            { category: "Genetics", q: "What is translation?", a: "The synthesis of a polypeptide (protein) using the genetic information encoded in an mRNA molecule." },
            { category: "Genetics", q: "What is the function of transfer RNA (tRNA)?", a: "To read the mRNA codon and bring the corresponding amino acid to the ribosome." },
            { category: "Genetics", q: "During mRNA processing in eukaryotes, which segments are removed (spliced out)?", a: "Introns (non-coding regions)." },
            { category: "Genetics", q: "What is an operon in bacteria?", a: "A cluster of functionally related genes controlled by a single promoter and operator." },
            { category: "Genetics", q: "Is the lac operon typically inducible or repressible?", a: "Inducible (usually off, turns on when lactose is present)." },
            { category: "Genetics", q: "What is epigenetics?", a: "Heritable changes in gene expression that do not involve changes to the underlying DNA sequence (e.g., DNA methylation)." },
            { category: "Genetics", q: "What is a silent mutation?", a: "A point mutation that changes a codon but still codes for the same amino acid, causing no change in the protein." },
            { category: "Genetics", q: "What is a missense mutation?", a: "A substitution mutation that results in a codon that codes for a different amino acid." },

            // MICROBIOLOGY
            { category: "Microbiology", q: "What is the main difference between prokaryotic and eukaryotic cells?", a: "Prokaryotes lack a membrane-bound nucleus; eukaryotes have them." },
            { category: "Microbiology", q: "Are viruses considered living organisms?", a: "Generally no, because they cannot reproduce or carry out metabolic processes without a host cell." },
            { category: "Microbiology", q: "What do antibiotics target?", a: "Bacterial infections. They are ineffective against viruses." },
            { category: "Microbiology", q: "What are the three basic shapes of bacteria?", a: "Coccus (spherical), Bacillus (rod-shaped), and Spirillum (spiral)." },
            { category: "Microbiology", q: "What phase of bacterial growth is characterized by rapid, exponential cell division?", a: "The log (exponential) phase." },

            // BOTANY
            { category: "Botany", q: "What is the simplified chemical equation for photosynthesis?", a: "6CO2 + 6H2O + Light Energy → C6H12O6 + 6O2" },
            { category: "Botany", q: "What is the role of stomata in plant leaves?", a: "Gas exchange (CO2 in, O2 out) and transpiration." },
            { category: "Botany", q: "Which plant hormone is a gas that triggers fruit ripening?", a: "Ethylene." },
            { category: "Botany", q: "Which plant hormone is responsible for phototropism?", a: "Auxin." },
            { category: "Botany", q: "Where does the Calvin cycle occur?", a: "In the stroma of the chloroplast." },

            // ZOOLOGY & ANATOMY
            { category: "Zoology", q: "What is homeostasis?", a: "Maintaining a stable internal environment despite external changes." },
            { category: "Zoology", q: "What is the basic functional cell of the nervous system?", a: "The neuron (nerve cell)." },
            { category: "Zoology", q: "Which blood vessels carry oxygenated blood AWAY from the heart?", a: "Arteries (except the pulmonary artery)." },
            { category: "Zoology", q: "What is the difference between an endotherm and an ectotherm?", a: "Endotherms generate heat internally; Ectotherms rely on environmental heat." },
            { category: "Zoology", q: "What is the functional unit of the kidney?", a: "The nephron." },

            // TAXONOMY
            { category: "Taxonomy", q: "What are the three major domains of life?", a: "Bacteria, Archaea, and Eukarya." },
            { category: "Taxonomy", q: "What is the correct order of the taxonomic hierarchy?", a: "Domain, Kingdom, Phylum, Class, Order, Family, Genus, Species." },
            { category: "Taxonomy", q: "Who is considered the father of modern taxonomy?", a: "Carl Linnaeus." },
            { category: "Taxonomy", q: "What constitutes a clade?", a: "A common ancestor and ALL of its descendants." },
            { category: "Taxonomy", q: "What evolutionary process leads to analogous structures?", a: "Convergent evolution." }
        ];

        // --- 2. DECK MAPPING LOGIC ---
        const flashcardDecks = {
            'physiology': database.filter(i => ["Biochem", "CellMol", "Microbiology"].includes(i.category)),
            'genetics': database.filter(i => i.category === 'Genetics'),
            'ecology': database.filter(i => i.category === 'Taxonomy'),
            'anatomy': database.filter(i => ["Zoology", "DevBio"].includes(i.category)),
            'phytohormones': database.filter(i => i.category === 'Botany')
        };

        let currentDeckData = [];
        let cardIndex = 0;

        function openFlashcardDeck(deckId) {
            currentDeckData = flashcardDecks[deckId] || database;
            cardIndex = 0;
            const overlay = document.getElementById('flashcard-overlay');
            const deckName = document.getElementById('deck-name');
            
            deckName.textContent = deckId.toUpperCase() + " Deck";
            overlay.classList.remove('hidden');
            overlay.classList.add('active');
            
            updateCard();
            document.body.style.overflow = 'hidden';
        }

        function closeFlashcardDeck() {
            const overlay = document.getElementById('flashcard-overlay');
            overlay.classList.add('hidden');
            overlay.classList.remove('active');
            document.body.style.overflow = 'auto';
        }

        function updateCard() {
            const card = currentDeckData[cardIndex];
            const flashcardEl = document.getElementById('flashcard-container');
            const counterEl = document.getElementById('card-counter');
            
            flashcardEl.classList.remove('flipped');
            counterEl.textContent = (cardIndex + 1) + " / " + (currentDeckData.length || 0);
            
            setTimeout(() => {
                document.getElementById('card-question').textContent = card ? card.q : "No Questions Available";
                document.getElementById('card-answer').textContent = card ? card.a : "N/A";
            }, 150);
        }

        function nextCard() {
            if (currentDeckData.length === 0) return;
            cardIndex = (cardIndex + 1) % currentDeckData.length;
            updateCard();
        }

        function prevCard() {
            if (currentDeckData.length === 0) return;
            cardIndex = (cardIndex - 1 + currentDeckData.length) % currentDeckData.length;
            updateCard();
        }

        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeFlashcardDeck();
            if (e.key === 'ArrowRight') nextCard();
            if (e.key === 'ArrowLeft') prevCard();
        });
    </script>
</body>
</html>
